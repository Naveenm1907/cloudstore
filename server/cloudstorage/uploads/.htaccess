# .htaccess — placed inside public_html/cloudstorage/uploads/

Options -Indexes

<FilesMatch "\.php$">
    Require all denied
</FilesMatch>

<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    # Required for Flutter web / browser clients hosted on another domain.
    Header always set Access-Control-Allow-Origin "https://cloudstore-rho.vercel.app"
    Header always set Access-Control-Allow-Methods "GET, HEAD, OPTIONS"
    Header always set Access-Control-Allow-Headers "Origin, Content-Type, Accept, X-Requested-With, X-API-Key"
</IfModule>
